generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Adapter Models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  REQUESTER
  APPROVER
  FLAVORIST
  QC_OFFICER
  PACKER
  SHIPPER
  ADMIN
}

enum RequestStatus {
  REQUESTED
  APPROVED
  REVISION_REQUESTED
  PREPARATION
  QC_CHECK
  QC_FAILED
  PACKING
  SHIPPED
  COMPLETED
  REJECTED
  CANCELLED
}

enum FlavorCategory {
  BEVERAGE
  DAIRY
  BAKERY
  CONFECTIONERY
  SAVOURY
  NUTRACEUTICAL
  ORAL_CARE
  TOBACCO
  PERSONAL_CARE
  PET_FOOD
  PHARMACEUTICAL
  OTHER
}

enum SampleType {
  OFF_SHELF
  NEW_CREATION
  MATCHING
  MODIFICATION
  GOLD_STANDARD
  PRODUCTION_TRIAL
  COST_REDUCTION
  REFORMULATION
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum FlavorDesignation {
  NATURAL
  NATURE_IDENTICAL
  ARTIFICIAL
  ORGANIC
  WONF
}

enum PhysicalForm {
  LIQUID
  POWDER
  PASTE
  EMULSION
  SPRAY_DRIED
  ENCAPSULATED
  OIL_SOLUBLE
  WATER_SOLUBLE
}

enum QcOutcome {
  PASS
  FAIL
  CONDITIONAL_PASS
}

enum QuantityUnit {
  G
  KG
  ML
  L
  OZ
  LB
  UNIT
}

enum ShippingCarrier {
  DHL
  FEDEX
  UPS
  LOCAL_COURIER
  HAND_DELIVERY
  OTHER
}

enum ShipTemp {
  AMBIENT
  CHILLED
  FROZEN
}

// ─── Application Models ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  image         String?
  emailVerified DateTime?
  role          Role      @default(REQUESTER)
  slackUserId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  requestsCreated SampleRequest[] @relation("Requester")
  auditLogs       AuditLog[]
  qcResultsTested QcResult[]      @relation("QcTester")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  company       String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  country       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requests SampleRequest[]

  @@index([name])
}

model SampleRequest {
  id                  String          @id @default(cuid())
  displayId           String          @unique
  customerName        String
  productName         String
  flavorCategory      FlavorCategory
  sampleType          SampleType
  quantity            String
  deadline            DateTime
  priority            Priority        @default(NORMAL)
  specialInstructions String?

  // ── Flavor house specifics (all optional for backward compat) ──
  flavorDesignation      FlavorDesignation?
  physicalForm           PhysicalForm?
  quantityValue          Float?
  quantityUnit           QuantityUnit?
  targetProfile          String?          // Desired flavor profile description
  referenceProduct       String?          // Reference product for matching
  regulatoryRequirements String?          // Halal, Kosher, allergen-free, etc.
  allergenInfo           String?          // Allergen declarations
  shelfLife              String?          // Expected shelf life requirement
  storageConditions      String?          // Storage conditions requirement

  // ── Workflow ──
  status              RequestStatus   @default(REQUESTED)
  currentAssigneeRole Role?

  // ── Relations ──
  requesterId String
  requester   User     @relation("Requester", fields: [requesterId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  auditLogs AuditLog[]
  images    Image[]
  qcResult  QcResult?
  shipment  Shipment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deadline])
  @@index([requesterId])
  @@index([customerId])
}

model AuditLog {
  id             String         @id @default(cuid())
  requestId      String
  request        SampleRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  previousStatus RequestStatus?
  newStatus      RequestStatus
  notes          String?
  createdAt      DateTime       @default(now())

  @@index([requestId])
  @@index([createdAt])
}

model Image {
  id         String        @id @default(cuid())
  requestId  String
  request    SampleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  gate       RequestStatus
  url        String
  filename   String
  uploadedBy String
  createdAt  DateTime      @default(now())

  @@index([requestId])
}

model QcResult {
  id              String        @id @default(cuid())
  requestId       String        @unique
  request         SampleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  outcome         QcOutcome
  appearance      Boolean       @default(true)
  aroma           Boolean       @default(true)
  taste           Boolean       @default(true)
  color           Boolean       @default(true)
  specificGravity Float?
  refractiveIndex Float?
  pH              Float?
  viscosity       Float?
  moistureContent Float?
  remarks         String?
  testedById      String
  testedBy        User          @relation("QcTester", fields: [testedById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([requestId])
}

model Shipment {
  id              String           @id @default(cuid())
  requestId       String           @unique
  request         SampleRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  carrier         ShippingCarrier?
  trackingNumber  String?
  shippingAddress String?
  recipientName   String?
  recipientPhone  String?
  temperature     ShipTemp         @default(AMBIENT)
  notes           String?
  docsIncluded    String[]
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([requestId])
}
